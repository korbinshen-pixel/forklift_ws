<?xml version="1.0"?>
<!--
  叉车URDF Xacro 文件
  适配: Ubuntu 22.04 + ROS2 Humble + Gazebo 11.10.2
  
  结构说明：
    base_footprint  → base_joint(fixed) → base_link
    base_link → left_wheel_joint(continuous) → left_wheel
    base_link → right_wheel_joint(continuous) → right_wheel
    base_link → front_left_caster_joint(fixed) → front_left_caster
    base_link → front_right_caster_joint(fixed) → front_right_caster
    base_link → mast_joint(fixed) → mast_link
    mast_link → fork_joint(prismatic) → fork_link
    base_link → rgbd_camera_joint(fixed) → rgbd_camera_link
    base_link → lidar_joint(fixed) → lidar_link
-->
<robot name="forklift" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== 常量定义 ==================== -->
  <!-- 底盘参数 -->
  <xacro:property name="base_length" value="1.8"/>   <!-- 底盘长度 m -->
  <xacro:property name="base_width" value="1.0"/>    <!-- 底盘宽度 m -->
  <xacro:property name="base_height" value="1.2"/>   <!-- 底盘高度 m -->
  <xacro:property name="base_mass" value="600.0"/>   <!-- 底盘质量 kg -->

  <!-- 驱动轮参数（后轮驱动）-->
  <xacro:property name="wheel_radius" value="0.25"/> <!-- 车轮半径 m -->
  <xacro:property name="wheel_width" value="0.15"/>  <!-- 车轮宽度 m -->
  <xacro:property name="wheel_mass" value="15.0"/>   <!-- 车轮质量 kg -->
  <!-- 驱动轮安装位置（底盘后部）-->
  <xacro:property name="wheel_x_offset" value="-0.6"/>   <!-- 相对底盘中心的X偏移 -->
  <xacro:property name="wheel_y_offset" value="0.575"/>   <!-- 相对底盘中心的Y偏移 -->
  <xacro:property name="wheel_z_offset" value="-0.35"/>   <!-- 相对底盘中心的Z偏移 -->

  <!-- 万向轮参数（前轮）-->
  <xacro:property name="caster_radius" value="0.1"/>  <!-- 万向轮半径 m -->
  <xacro:property name="caster_mass" value="3.0"/>    <!-- 万向轮质量 kg -->
  <!-- 万向轮安装位置（底盘前部）-->
  <xacro:property name="caster_x_offset" value="0.7"/>
  <xacro:property name="caster_y_offset" value="0.35"/>
  <xacro:property name="caster_z_offset" value="-0.5"/>

  <!-- 门架参数 -->
  <xacro:property name="mast_height" value="1.5"/>   <!-- 门架高度 m -->
  <xacro:property name="mast_width" value="0.08"/>   <!-- 门架宽度 m -->
  <xacro:property name="mast_depth" value="0.08"/>   <!-- 门架深度 m -->
  <xacro:property name="mast_mass" value="80.0"/>    <!-- 门架质量 kg -->

  <!-- 货叉参数 -->
  <xacro:property name="fork_length" value="1.2"/>   <!-- 货叉长度 m -->
  <xacro:property name="fork_width" value="0.12"/>   <!-- 货叉宽度 m -->
  <xacro:property name="fork_height" value="0.05"/>  <!-- 货叉高度 m -->
  <xacro:property name="fork_mass" value="30.0"/>    <!-- 货叉质量 kg -->


  <!-- ==================== 材质颜色定义 ==================== -->
  <!-- 底盘颜色：工业黄色 -->
  <material name="forklift_yellow">
    <color rgba="1.0 0.8 0.0 1.0"/>
  </material>

  <!-- 货叉颜色：橙色 -->
  <material name="fork_orange">
    <color rgba="1.0 0.4 0.0 1.0"/>
  </material>

  <!-- 车轮颜色：深灰色 -->
  <material name="wheel_dark_gray">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <!-- 相机颜色：黑色 -->
  <material name="sensor_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- 门架颜色：金属灰 -->
  <material name="mast_gray">
    <color rgba="0.5 0.5 0.55 1.0"/>
  </material>

  <!-- ==================== 惯量计算宏 ==================== -->
  <!-- 实心长方体惯量 -->
  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (y*y + z*z)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0) * mass * (x*x + z*z)}"
        iyz="0.0"
        izz="${(1.0/12.0) * mass * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- 实心圆柱体惯量（圆柱轴沿Z轴）-->
  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        iyz="0.0"
        izz="${0.5 * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- 实心球体惯量 -->
  <xacro:macro name="sphere_inertia" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${(2.0/5.0) * mass * radius * radius}"
        ixy="0.0" ixz="0.0"
        iyy="${(2.0/5.0) * mass * radius * radius}"
        iyz="0.0"
        izz="${(2.0/5.0) * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== 车轮宏定义 ==================== -->
  <xacro:macro name="drive_wheel" params="name x_pos y_pos z_pos reflect">
    <link name="${name}">
      <!-- 车轮圆柱体，旋转90度使轴沿Y轴 -->
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <!-- 圆柱惯量（轴沿Y轴，因此交换ixx/izz）-->
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${(1.0/12.0) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          ixy="0.0" ixz="0.0"
          iyy="${0.5 * wheel_mass * wheel_radius * wheel_radius}"
          iyz="0.0"
          izz="${(1.0/12.0) * wheel_mass * (3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x_pos} ${y_pos * reflect} ${z_pos}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <!-- 设置关节摩擦和阻尼 -->
      <dynamics damping="0.5" friction="0.5"/>
      <!-- 限制速度和力矩 -->
      <limit velocity="10.0" effort="500.0"/>
    </joint>

    <!-- 车轮与地面摩擦配置（Gazebo）-->
    <gazebo reference="${name}">
      <material>Gazebo/DarkGrey</material>
      <mu1>0.9</mu1>
      <mu2>0.9</mu2>
      <kp>1000000.0</kp>
      <kd>10.0</kd>
      <minDepth>0.001</minDepth>
    </gazebo>
  </xacro:macro>

  <!-- ==================== 万向轮宏定义 ==================== -->
  <xacro:macro name="caster_wheel" params="name x_pos y_pos z_pos reflect">
    <link name="${name}">
      <!-- 使用球形简化万向轮碰撞体 -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="wheel_dark_gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <xacro:sphere_inertia mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x_pos} ${y_pos * reflect} ${z_pos}" rpy="0 0 0"/>
    </joint>

    <!-- 万向轮低摩擦配置（Gazebo）-->
    <gazebo reference="${name}">
      <material>Gazebo/DarkGrey</material>
      <mu1>0.01</mu1>
      <mu2>0.01</mu2>
      <kp>1000000.0</kp>
      <kd>10.0</kd>
    </gazebo>
  </xacro:macro>

  <!-- ==================== 链接定义 ==================== -->

  <!-- 1. base_footprint: 机器人足迹参考点（位于地面）-->
  <link name="base_footprint">
    <!-- base_footprint是虚拟link，无可视化和碰撞体 -->
  </link>

  <!-- base_footprint → base_link 固定关节 -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- 底盘中心距地面的高度 = 车轮半径 -->
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- 2. base_link: 叉车主体底盘 -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="forklift_yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <!-- Gazebo底盘颜色 -->
  <gazebo reference="base_link">
    <material>Gazebo/Yellow</material>
  </gazebo>

  <!-- 3 & 4. 驱动轮（后轮）：左右各一 -->
  <xacro:drive_wheel name="left_wheel"
    x_pos="${wheel_x_offset}"
    y_pos="${wheel_y_offset}"
    z_pos="${wheel_z_offset}"
    reflect="1"/>

  <xacro:drive_wheel name="right_wheel"
    x_pos="${wheel_x_offset}"
    y_pos="${wheel_y_offset}"
    z_pos="${wheel_z_offset}"
    reflect="-1"/>

  <!-- 5 & 6. 万向轮（前轮）：左右各一 -->
  <xacro:caster_wheel name="front_left_caster"
    x_pos="${caster_x_offset}"
    y_pos="${caster_y_offset}"
    z_pos="${caster_z_offset}"
    reflect="1"/>

  <xacro:caster_wheel name="front_right_caster"
    x_pos="${caster_x_offset}"
    y_pos="${caster_y_offset}"
    z_pos="${caster_z_offset}"
    reflect="-1"/>

  <!-- 7. mast_link: 门架（叉车前端立柱）-->
  <link name="mast_link">
    <!-- 左侧立柱 -->
    <visual>
      <origin xyz="0 ${0.3} ${mast_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_depth} ${mast_width} ${mast_height}"/>
      </geometry>
      <material name="mast_gray"/>
    </visual>
    <!-- 右侧立柱 -->
    <visual>
      <origin xyz="0 ${-0.3} ${mast_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_depth} ${mast_width} ${mast_height}"/>
      </geometry>
      <material name="mast_gray"/>
    </visual>
    <!-- 横梁 -->
    <visual>
      <origin xyz="0 0 ${mast_height}" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_depth} 0.7 ${mast_width}"/>
      </geometry>
      <material name="mast_gray"/>
    </visual>
    <!-- 碰撞体：用单一box简化 -->
    <collision>
      <origin xyz="0 0 ${mast_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_depth} 0.7 ${mast_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="${mast_mass}" x="${mast_depth}" y="0.7" z="${mast_height}"/>
  </link>

  <!-- base_link → mast_link 固定关节（门架在底盘前端）-->
  <joint name="mast_joint_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="mast_link"/>
    <!-- 门架安装在底盘前端，底盘顶部 -->
    <origin xyz="${base_length/2 - mast_depth/2} 0 ${base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo门架颜色 -->
  <gazebo reference="mast_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- 8. fork_link: 货叉（L形结构）-->
  <link name="fork_link">
    <!-- 货叉横梁（连接两叉的横杆）-->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_depth} 0.65 ${fork_height}"/>
      </geometry>
      <material name="fork_orange"/>
    </visual>
    <!-- 左货叉臂 -->
    <visual>
      <origin xyz="${fork_length/2} ${0.25} ${-fork_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${fork_length} ${fork_width} ${fork_height}"/>
      </geometry>
      <material name="fork_orange"/>
    </visual>
    <!-- 右货叉臂 -->
    <visual>
      <origin xyz="${fork_length/2} ${-0.25} ${-fork_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${fork_length} ${fork_width} ${fork_height}"/>
      </geometry>
      <material name="fork_orange"/>
    </visual>
    <!-- 货叉碰撞体（简化为三个box）-->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_depth} 0.65 ${fork_height}"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="${fork_length/2} ${0.25} ${-fork_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${fork_length} ${fork_width} ${fork_height}"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="${fork_length/2} ${-0.25} ${-fork_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${fork_length} ${fork_width} ${fork_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="${fork_mass}" x="${fork_length}" y="0.65" z="${fork_height}"/>
  </link>

  <!-- mast_link → fork_link 棱柱关节（货叉可沿门架上下移动）-->
  <joint name="fork_joint" type="prismatic">
    <parent link="mast_link"/>
    <child link="fork_link"/>
    <!-- 初始位置：货叉收起在底部 -->
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <!-- 沿Z轴（垂直）移动 -->
    <axis xyz="0 0 1"/>
    <!-- 行程：0 ~ 1.5m -->
    <limit lower="0.0" upper="1.5" effort="5000.0" velocity="0.5"/>
    <dynamics damping="10.0" friction="5.0"/>
  </joint>

  <!-- Gazebo货叉颜色 -->
  <gazebo reference="fork_link">
    <material>Gazebo/Orange</material>
  </gazebo>

  <!-- 9. rgbd_camera_link: 深度相机（底盘前上方）-->
  <link name="rgbd_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.15 0.04"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.15 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- base_link → rgbd_camera_link 固定关节 -->
  <joint name="rgbd_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rgbd_camera_link"/>
    <!-- 相机安装在底盘前上方
         base_footprint坐标：x=0.5（前方），z=1.3（高度）
         相对base_link中心：x=0.5, z=1.05（base_joint_z=0.25, 1.3-0.25=1.05）-->
    <origin xyz="0.5 0 1.05" rpy="0 0.1 0"/>
  </joint>

  <!-- Gazebo深度相机颜色 -->
  <gazebo reference="rgbd_camera_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- 深度相机Gazebo传感器插件 -->
  <gazebo reference="rgbd_camera_link">
    <sensor type="depth" name="rgbd_camera">
      <update_rate>30.0</update_rate>
      <camera name="rgbd_camera">
        <horizontal_fov>1.0472</horizontal_fov>  <!-- 60度水平视角 -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin name="color_camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/camera</namespace>
          <remapping>~/image_raw:=/camera/color/image_raw</remapping>
          <remapping>~/camera_info:=/camera/color/camera_info</remapping>
        </ros>
        <camera_name>color_camera</camera_name>
        <frame_name>rgbd_camera_link</frame_name>
      </plugin>
      <plugin name="depth_camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/camera</namespace>
          <remapping>~/image_raw:=depth/image_raw</remapping>
          <remapping>~/camera_info:=depth/camera_info</remapping>
          <remapping>~/points:=depth/points</remapping>
        </ros>
        <camera_name>depth_camera</camera_name>
        <frame_name>rgbd_camera_link</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>10.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <!-- 10. lidar_link: 2D激光雷达（底盘顶部中央）-->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
      <material name="sensor_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- base_link → lidar_link 固定关节 -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- 雷达安装在底盘顶部中央
         base_footprint坐标：z=1.5（高度）
         相对base_link中心：z=1.25（base_joint_z=0.25, 1.5-0.25=1.25）-->
    <origin xyz="0 0 1.25" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo激光雷达颜色 -->
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- 2D激光雷达Gazebo传感器插件 -->
  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <!-- 270度扫描范围，分辨率0.5度 -->
            <samples>540</samples>
            <resolution>1</resolution>
            <min_angle>${-135.0 * pi / 180.0}</min_angle>
            <max_angle>${135.0 * pi / 180.0}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>30.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ==================== Gazebo差速驱动插件 ==================== -->
  <!--
    差速驱动控制器：
    - 订阅 /cmd_vel (geometry_msgs/Twist) 控制运动
    - 发布 /odom (nav_msgs/Odometry) 里程计信息
    - 轮距 = wheel_y_offset * 2 = 1.15m（两驱动轮间距）
  -->
  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <!-- 更新频率 -->
      <update_rate>50</update_rate>
      <!-- 左右驱动轮关节名称 -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <!-- 车轮参数 -->
      <wheel_separation>1.15</wheel_separation>   <!-- 两轮中心间距 m -->
      <wheel_diameter>${2 * wheel_radius}</wheel_diameter>
      <!-- 最大加速度和扭矩 -->
      <max_wheel_torque>500</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <!-- 命令话题和里程计话题 -->
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <!-- 发布TF变换 -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>
  </gazebo>

</robot>
